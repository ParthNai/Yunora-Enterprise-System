{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "dev": "pnpm -r --parallel --if-present run dev",
    "dev:admin": "pnpm --filter @workspace/yunora-admin run dev",
    "dev:api": "pnpm --filter @workspace/api-server run dev",
    "dev:mockup": "pnpm --filter @workspace/mockup-sandbox run dev",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "prettier": "^3.8.3",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "firebase": "^12.15.0"
  }
}